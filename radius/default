server default {
    listen {
        type = auth
        ipaddr = *
        port = 0
    }

    listen {
        ipaddr = *
        port = 0
        type = acct
    }

    authorize {
        # Eğer User-Name MAC formatındaysa (xx:xx:xx:xx:xx:xx) MAB olarak işaretle
        if (User-Name =~ /^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$/) {
            update control {
                Auth-Type := Accept
            }
        }
        else {
            # REST API'yi çağır - kullanıcıyı tanıyorsa Auth-Type = rest olarak ayarla
            rest
            if (ok || updated) {
                update control {
                    Auth-Type := rest
                }
            }
        }
    }

    authenticate {
        # REST API üzerinden bcrypt doğrulaması
        Auth-Type rest {
            rest
        }
        Auth-Type PAP {
            pap
        }
        Auth-Type Accept {
            ok
        }
    }

    # MAB için post-auth bloğu
    post-auth {
        if (Calling-Station-Id) {
            rest
        }
        Post-Auth-Type REJECT {
            ok
        }
    }

    accounting {
        rest
    }
}

